{
  "core_000001": {
    "en": "The woman works in the house.",
    "it": "La donna lavora in casa."
  },
  "core_000002": {
    "en": "I see the man and the woman.",
    "it": "Vedo l'uomo e la donna."
  },
  "core_000003": {
    "en": "The child is in the house.",
    "it": "Il bambino è in casa."
  },
  "core_000004": {
    "en": "This is the man's house.",
    "it": "Questa è la casa dell'uomo."
  },
  "core_000005": {
    "en": "He stands in the place.",
    "it": "Lui sta in piedi nel luogo."
  },
  "core_000006": {
    "en": "She is a good woman.",
    "it": "Lei è una brava donna."
  },
  "core_000007": {
    "en": "It is not otherwise.",
    "it": "Non è altrimenti."
  },
  "core_000008": {
    "en": "He has a house.",
    "it": "Lui ha una casa."
  },
  "core_000009": {
    "en": "This is good for the child.",
    "it": "Questo fa bene al bambino."
  },
  "core_000010": {
    "en": "I know the man who is standing there.",
    "it": "Conosco l'uomo che sta lì."
  },
  "core_000011": {
    "en": "He is going with her.",
    "it": "Lui va con lei."
  },
  "core_000012": {
    "en": "It is time to go.",
    "it": "È ora di andare."
  },
  "core_000013": {
    "en": "We have a big house.",
    "it": "Abbiamo una casa grande."
  },
  "core_000014": {
    "en": "That is not possible.",
    "it": "Non è possibile."
  },
  "core_000015": {
    "en": "He thinks of her.",
    "it": "Lui pensa a lei."
  },
  "core_000016": {
    "en": "She is coming too.",
    "it": "Anche lei viene."
  },
  "core_000017": {
    "en": "There are many people in the world.",
    "it": "Ci sono molte persone nel mondo."
  },
  "core_000018": {
    "en": "If he comes, we'll go.",
    "it": "Se lui viene, andiamo."
  },
  "core_000019": {
    "en": "She has a lot of time.",
    "it": "Lei ha molto tempo."
  },
  "core_000020": {
    "en": "We can do that.",
    "it": "Possiamo farlo."
  },
  "core_000021": {
    "en": "He says that he is coming.",
    "it": "Dice che sta arrivando."
  },
  "core_000022": {
    "en": "He comes around that time.",
    "it": "Arriva verso quell'ora."
  },
  "core_000023": {
    "en": "The child is growing up.",
    "it": "Il bambino sta crescendo."
  },
  "core_000024": {
    "en": "That is my house.",
    "it": "Quella è la mia casa."
  },
  "core_000025": {
    "en": "She is still young.",
    "it": "Lei è ancora giovane."
  },
  "core_000026": {
    "en": "I want to go, but I can't.",
    "it": "Voglio andare, ma non posso."
  },
  "core_000027": {
    "en": "She is with her husband.",
    "it": "Lei è con suo marito."
  },
  "core_000028": {
    "en": "She is coming today.",
    "it": "Lei arriva oggi."
  },
  "core_000029": {
    "en": "We are going to the house.",
    "it": "Andiamo verso la casa."
  },
  "core_000030": {
    "en": "He comes from another country.",
    "it": "Lui viene da un altro paese."
  },
  "core_000031": {
    "en": "We are going to work.",
    "it": "Andiamo al lavoro."
  },
  "core_000032": {
    "en": "She comes every day.",
    "it": "Lei viene ogni giorno."
  },
  "core_000033": {
    "en": "We will do that.",
    "it": "Lo faremo."
  },
  "core_000034": {
    "en": "Is he going or is he staying?",
    "it": "Va o resta?"
  },
  "core_000035": {
    "en": "He thinks about the problem.",
    "it": "Lui pensa al problema."
  },
  "core_000036": {
    "en": "I have to go home now.",
    "it": "Devo andare a casa adesso."
  },
  "core_000037": {
    "en": "She walks through the house.",
    "it": "Lei cammina per la casa."
  },
  "core_000038": {
    "en": "He is already there.",
    "it": "Lui è già lì."
  },
  "core_000039": {
    "en": "I have no time.",
    "it": "Non ho tempo."
  },
  "core_000040": {
    "en": "First this, then that.",
    "it": "Prima questo, poi quello."
  },
  "core_000041": {
    "en": "This house is good.",
    "it": "Questa casa è buona."
  },
  "core_000042": {
    "en": "I think so.",
    "it": "Lo penso."
  },
  "core_000043": {
    "en": "He makes the house beautiful.",
    "it": "Lui rende la casa bella."
  },
  "core_000044": {
    "en": "We work until that time.",
    "it": "Lavoriamo fino a quell'ora."
  },
  "core_000045": {
    "en": "He is a good man.",
    "it": "Lui è un brav'uomo."
  },
  "core_000046": {
    "en": "We did what we had to do.",
    "it": "Abbiamo fatto quello che dovevamo fare."
  },
  "core_000047": {
    "en": "It is so clear.",
    "it": "È così chiaro."
  },
  "core_000048": {
    "en": "We are going home now.",
    "it": "Andiamo a casa adesso."
  },
  "core_000049": {
    "en": "That is his house.",
    "it": "Quella è la sua casa."
  },
  "core_000050": {
    "en": "This year is a good year.",
    "it": "Quest'anno è un buon anno."
  }
}